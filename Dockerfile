# 1. שימוש בגרסה רשמית וקלה של Node
FROM node:18-slim

# 2. הגדרת תיקיית העבודה בתוך הקונטיינר
WORKDIR /usr/src/app

# 3. העתקת קבצי הגדרות והתקנת חבילות (לפני העתקת כל הקוד כדי לחסוך זמן בבנייה)
COPY package*.json ./
RUN npm install

# 4. העתקת כל שאר קבצי הפרויקט
COPY . .

# 5. חשיפת הפורט שבו השרת שלנו מאזין
EXPOSE 3000

# 6. הפקודה שתריץ את השרת ברגע שהקונטיינר עולה
CMD [ "node", "server.js" ]